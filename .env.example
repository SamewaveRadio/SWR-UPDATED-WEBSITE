# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# AzuraCast — server-side only (used by Vercel serverless functions)
AZURACAST_API_BASE=http://89.167.70.233/api
AZURACAST_STATION_ID=samewave_radio

# AzuraCast stream — must be an HTTPS URL for browser playback
# Get this from your AzuraCast admin or configure a reverse proxy with SSL, e.g.:
# https://radio.samewave-radio.com/listen/samewave_radio/radio.mp3
VITE_AZURACAST_STREAM_URL=https://YOUR-AZURACAST-DOMAIN/listen/samewave_radio/radio.mp3
